generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String
  avatar        String         @default("Summbix")
  bio           String         @default("Master of Discipline")
  isVerified    Boolean        @default(false)
  otpCode       String?
  otpExpires    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  focusSessions FocusSession[]
  goals         Goal[]
  habits        Habit[]
  notifications Notification[]
  tasks         Task[]

  @@map("users")
}

model Goal {
  id            String         @id @default(cuid())
  title         String
  description   String         @default("")
  color         String         @default("#E38569")
  startDate     DateTime
  deadline      DateTime
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  focusSessions FocusSession[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  habits        Habit[]
  tasks         Task[]

  @@index([userId])
  @@map("goals")
}

model Task {
  id            String         @id @default(cuid())
  title         String
  completed     Boolean        @default(false)
  priority      String         @default("medium")
  date          String?
  startTime     String?
  endTime       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  goalId        String?
  focusSessions FocusSession[]
  goal          Goal?          @relation(fields: [goalId], references: [id])
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([goalId])
  @@map("tasks")
}

model Habit {
  id             String         @id @default(cuid())
  label          String
  startTime      String?
  endTime        String?
  completedDates String[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  userId         String
  goalId         String?
  focusSessions  FocusSession[]
  goal           Goal?          @relation(fields: [goalId], references: [id])
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([goalId])
  @@map("habits")
}

model FocusSession {
  id        String   @id @default(cuid())
  date      String
  duration  Int
  title     String?
  createdAt DateTime @default(now())
  userId    String
  goalId    String?
  taskId    String?
  habitId   String?
  goal      Goal?    @relation(fields: [goalId], references: [id])
  habit     Habit?   @relation(fields: [habitId], references: [id])
  task      Task?    @relation(fields: [taskId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([goalId])
  @@map("focus_sessions")
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("system")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}
